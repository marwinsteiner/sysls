{
  "mcpServers": {
    "slack": {
      "command": "npx",
      "args": ["-y", "slack-mcp-server@latest", "--transport", "stdio"],
      "env": {
        "SLACK_MCP_XOXP_TOKEN": "xoxp-REPLACE-WITH-YOUR-TOKEN",
        "SLACK_MCP_ADD_MESSAGE_TOOL": "true",
        "SLACK_MCP_MARK_MESSAGES_AS_READ": "true"
      }
    }
  }
}
